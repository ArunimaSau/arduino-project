Designed and developed a proximity detection system using an HC-SR04 ultrasonic sensor and Arduino UNO
Calculated object distance using time-of-flight principle of ultrasonic waves
Implemented conditional logic to control multiple LEDs based on distance thresholds
Programmed real-time distance measurement and visual alert indication
Gained hands-on experience in sensor interfacing, digital I/O control, and embedded system programming

int trig=3;
int echo=4;
int timeinMicro=0;
long distanceInCm;


void setup() {
  // put your setup code here, to run once:
  Serial.begin(9600);
pinMode(3,OUTPUT);
pinMode(4,INPUT);
pinMode(5,OUTPUT);
pinMode(6,OUTPUT);
pinMode(7,OUTPUT);
pinMode(8,OUTPUT);
pinMode(9,OUTPUT);
pinMode(10,OUTPUT);
digitalWrite(5,LOW);
digitalWrite(6,LOW);
digitalWrite(7,LOW);
digitalWrite(8,LOW);
digitalWrite(9,LOW);
digitalWrite(10,LOW);

}

void loop() {
  // put your main code here, to run repeatedly:

digitalWrite(trig,LOW);
delayMicroseconds(2);
digitalWrite(trig,HIGH);
delayMicroseconds(10);
digitalWrite(trig,LOW);

timeinMicro=pulseIn(echo,HIGH);
distanceInCm=timeinMicro/(29*2);
Serial.println("Distance is : ");
Serial.println(distanceInCm);
delay(2000);
if(distanceInCm<20){
  digitalWrite(5,HIGH);
}
else 
digitalWrite(5,LOW);

if(distanceInCm<16){
  digitalWrite(6,HIGH);
}
else
digitalWrite(6,LOW);

if(distanceInCm<12){
  digitalWrite(7,HIGH);
}
else
digitalWrite(7,LOW);

if(distanceInCm<8){
  digitalWrite(8,HIGH);
}
else
digitalWrite(8,LOW);
if(distanceInCm<5){
  digitalWrite(9,HIGH);
}
else
digitalWrite(9,LOW);
if(distanceInCm<3){
  digitalWrite(10,HIGH);
}
else
digitalWrite(10,LOW);
}

